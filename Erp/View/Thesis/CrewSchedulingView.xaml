                                        <TextBox Grid.Row="4"  Grid.Column="1" Text="{Binding InputData.ColgenSettings.MinHoursBetween, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="4"  Grid.Column="3" Text="{Binding InputData.ColgenSettings.LatestArrivalTime, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="4"  Grid.Column="5" Text="{Binding InputData.ColgenSettings.EarliestDepartureTime, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="5"  Grid.Column="1" Text="{Binding InputData.ColgenSettings.XHoursBreak, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="5"  Grid.Column="3" Text="{Binding InputData.ColgenSettings.YFlightHours, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="5"  Grid.Column="5" Text="{Binding InputData.ColgenSettings.MaximumFlightHours, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="6"  Grid.Column="1" Text="{Binding InputData.ColgenSettings.UndercoverCost, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="6"  Grid.Column="3" Text="{Binding InputData.ColgenSettings.HourPenalty, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="6"  Grid.Column="5" Text="{Binding InputData.ColgenSettings.MaxDouble, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="7"  Grid.Column="1" Text="{Binding InputData.ColgenSettings.Eps, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="7"  Grid.Column="3" Text="{Binding InputData.ColgenSettings.NumberOfTreeNodesLimit, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />

                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="Black" BorderThickness="1" Grid.Row="1" Grid.Column ="0"  Margin="5" IsEnabled="{Binding InputData.ShowColgenSettings, Mode=TwoWay}"  >
                                <StackPanel>
                                    <TextBlock Text="Colgen Settings " FontWeight="Bold" HorizontalAlignment="Center" Margin="5"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>

                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Buckets : " Grid.Row="1" Grid.Column="0" Margin="2"/>
                                        <TextBlock Text="Fict Buckets : " Grid.Row="1" Grid.Column="2" Margin="2"/>
                                        <TextBlock Text="Reduced Cost Cut : " Grid.Row="2" Grid.Column="0" Margin="2"/>
                                        <TextBlock Text="NIDRAI : " Grid.Row="2" Grid.Column="2" Margin="2"/>
                                        <TextBlock Text="Update Duals Manually Scheme : " Grid.Row="3" Grid.Column="0" Margin="2"/>
                                        <TextBlock Text="Abs Backtrack : " Grid.Row="3" Grid.Column="2" Margin="2"/>
                                        <TextBlock Text="Perce Backtrack : " Grid.Row="4" Grid.Column="0" Margin="2"/>
                                        <TextBlock Text="Abs MIP : " Grid.Row="4" Grid.Column="2" Margin="2"/>
                                        <TextBlock Text="Perce MIP : " Grid.Row="5" Grid.Column="0" Margin="2"/>
                                        <TextBlock Text="Number Of Backtracks Limit : " Grid.Row="5" Grid.Column="2" Margin="2"/>
                                        <TextBlock Text="Number Of TreeNodes Limit : " Grid.Row="6" Grid.Column="0" Margin="2"/>
                                        <TextBlock Text="Tree list Sorting Ids Fixed : " Grid.Row="6" Grid.Column="2" Margin="2"/>

                                        <TextBox Grid.Row="1"  Grid.Column="1" Text="{Binding InputData.ColgenSettings.Buckets, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="1"  Grid.Column="3" Text="{Binding InputData.ColgenSettings.FictBuckets, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="2"  Grid.Column="1" Text="{Binding InputData.ColgenSettings.ReducedCostCut, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="2"  Grid.Column="3" Text="{Binding InputData.ColgenSettings.NIDRAI, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="3"  Grid.Column="1" Text="{Binding InputData.ColgenSettings.UpdateDualsManuallyScheme, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="3"  Grid.Column="3" Text="{Binding InputData.ColgenSettings.AbsBacktrack, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="4"  Grid.Column="1" Text="{Binding InputData.ColgenSettings.PerceBacktrack, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="4"  Grid.Column="3" Text="{Binding InputData.ColgenSettings.AbsMIP, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="5"  Grid.Column="1" Text="{Binding InputData.ColgenSettings.PerceMIP, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="5"  Grid.Column="3" Text="{Binding InputData.ColgenSettings.NumberOfBacktracksLimit, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="6"  Grid.Column="1" Text="{Binding InputData.ColgenSettings.NumberOfTreeNodesLimit, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />
                                        <TextBox Grid.Row="6"  Grid.Column="3" Text="{Binding InputData.ColgenSettings.TreelistSortingIdsFixed, Mode=TwoWay}" HorizontalAlignment="Stretch" Width="182" />

                                    </Grid>
                                </StackPanel>
                            </Border>

                        </Grid>

                        <StackPanel  HorizontalAlignment="Left" Orientation="Horizontal">

                            <ToggleButton x:Name = "tb2" Content = "Show Colgen Settings"  
                            IsChecked="{Binding InputData.ShowColgenSettings, Mode=TwoWay}"  Margin = "15,2,2,2"  Background="Beige" BorderBrush="Black" 
                            Width = "200" HorizontalAlignment = "Center" >
                            </ToggleButton>
                            <ToggleButton x:Name = "tb3" Content = "Random Data"  
                            IsChecked="{Binding InputData.RandomDataFlag, Mode=TwoWay}"  Margin = "15,2,2,2"  Background="Beige" BorderBrush="Black" 
                            Width = "200" HorizontalAlignment = "Center" >
                            </ToggleButton>
                            <Button x:Name="Calculate_Colgen"   HorizontalAlignment="Left" Margin="4" Width="230" Command="{Binding CalculateColgen}">
                                <TextBlock Text="Calculate Colgen" />
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </TabItem>
                <TabItem Header="Optimization Results">
                    <TabControl>
                        <TabItem Header="Results">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="770"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>

                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Objective Value : " Grid.Row="0" Grid.Column="0" Margin="2"/>
                                <TextBox Text="{Binding OutputData.ObjValue, Mode=TwoWay}" Grid.Row="0" Grid.Column="1"  HorizontalAlignment="Stretch" Width="135" Margin="2" IsEnabled="False"/>
                                <TextBlock Text="CS Type : " Grid.Row="0" Grid.Column="2" Margin="2"/>
                                <TextBox Text="{Binding InputData.CSType, Mode=TwoWay}" Grid.Row="0" Grid.Column="3"  HorizontalAlignment="Stretch" Width="135" Margin="2" IsEnabled="False"/>



                            </Grid>
                        </TabItem>
                    </TabControl>
                </TabItem>
            </TabControl>
        </StackPanel>

    </Grid>
</UserControl>
