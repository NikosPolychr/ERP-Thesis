<Window x:Class="Erp.CustomControls.F7PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Erp.CustomControls" 
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        mc:Ignorable="d"
        Title="F7PopupWindow" 
        Height="380" Width="730"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/Images/popupwindow.PNG"
        >
    <Border BorderThickness="6" BorderBrush="#001F4D" CornerRadius="5" Background="White" Padding="0">
        <Grid>
            <DockPanel LastChildFill="True">
                <!-- Title bar -->
                <Border Background="#001F4D" Height="30" DockPanel.Dock="Top"
>
                    <DockPanel>
                        <!-- Optional: Add an Image for logo inside title bar -->

                        <TextBlock x:Name="TitleTextBlock" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" Margin="10,0" Text="Popup Title" 
                                   />
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" 
                                    FlowDirection="RightToLeft"
                                    MouseLeftButtonDown="pnlControlBar_MouseLeftButtonDown"
                                    MouseEnter="pnlControlBar_MouseEnter"
                                    Margin="0,0,5,0">


                            <Button x:Name ="BtnClose"
                          Style="{StaticResource controlButton}"
                          Tag ="{StaticResource color4}"
                          Click="CloseButton_Click">
                                <fa:IconImage Icon="Xmark" Style="{StaticResource controlButtonIcon}" />
                            </Button>
                            <Button x:Name ="BtnMaximize"
                                Style="{StaticResource controlButton}"
                                Tag ="{StaticResource color6}"
                                Click="MaximizeButton_Click">
                                <fa:IconImage Icon="Square" Style="{StaticResource controlButtonIcon}" />
                            </Button>
                            <Button x:Name ="BtnMinimize"
                                Style="{StaticResource controlButton}"
                                Tag ="{StaticResource color8}"
                                Click="MinimizeButton_Click">
                                <fa:IconImage Icon="WindowMinimize" Width="12" Style="{StaticResource controlButtonIcon}"/>
                            </Button>

                        </StackPanel>
                        
                        
                    </DockPanel>
                    
                </Border>
                <!-- Your UserControl -->
                <local:F7Popup x:Name="F7PopupControl" />
            </DockPanel>
        </Grid>
    </Border>
</Window>